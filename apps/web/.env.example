# Database (Neon PostgreSQL — use pooled connection string)
DATABASE_URL="postgresql://user:password@host:5432/storycapture?sslmode=require"

# Auth.js / NextAuth v5
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_GITHUB_ID="your-github-oauth-app-client-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-client-secret"
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"

# Cloudflare R2 (S3-compatible storage for videos + thumbnails)
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="storycapture-videos"
R2_PUBLIC_URL="https://cdn.storycapture.app"

# Desktop-web JWT auth (for SSE subscriptions)
JWT_SECRET="generate-with: openssl rand -base64 32"

# MaxMind GeoLite2 (country-level IP lookup for analytics)
MAXMIND_LICENSE_KEY="your-maxmind-license-key"

# Resend (workspace invite emails)
RESEND_API_KEY="re_your_resend_api_key"
