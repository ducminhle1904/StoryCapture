# ============================================================
# StoryCapture Web Companion — Environment Variables
# ============================================================
# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# On Vercel: Settings > Environment Variables
# ============================================================

# ---------- Database (Neon PostgreSQL) ----------
# Use the pooled connection URL from Neon dashboard.
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/storycapture?sslmode=require"

# ---------- Auth (NextAuth v5 / Auth.js) ----------
# Generate: openssl rand -base64 32
AUTH_SECRET=""

# GitHub OAuth App — https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google OAuth Client — https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ---------- JWT (Desktop-Web Token Exchange) ----------
# Generate: openssl rand -base64 32
JWT_SECRET=""

# ---------- Cloudflare R2 (Video + Thumbnail Storage) ----------
# From Cloudflare dashboard > R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="storycapture-media"

# ---------- Email (Resend — Workspace Invites) ----------
# Free tier: 100 emails/day — https://resend.com/api-keys
RESEND_API_KEY=""

# ---------- MaxMind GeoLite2 (Analytics GeoIP) ----------
# Free license key — https://www.maxmind.com/en/geolite2/signup
MAXMIND_LICENSE_KEY=""

# ---------- Cron Security ----------
# Generate: openssl rand -hex 16
CRON_SECRET=""

# ---------- Optional ----------
# Override public URL (defaults to http://localhost:3000 in dev)
# NEXTAUTH_URL="http://localhost:3000"
