{
  "name": "@storycapture/desktop",
  "private": true,
  "version": "0.1.0",
  "description": "StoryCapture desktop app for turning story scripts into polished demo videos.",
  "author": "StoryCapture",
  "type": "module",
  "main": "dist-electron/main.mjs",
  "scripts": {
    "dev": "pnpm electron:dev",
    "dev:recording-v3": "node scripts/dev-recording-v3.mjs",
    "build": "pnpm electron:build",
    "renderer:dev": "vite",
    "renderer:build": "tsc -b && vite build",
    "electron:build": "pnpm native:build && pnpm electron:build-main && pnpm renderer:build && electron-builder",
    "electron:build-main": "node scripts/build-electron.mjs",
    "electron:dev": "node scripts/dev-electron.mjs",
    "electron:start": "node scripts/start-dev-electron.mjs",
    "electron:prepare-dev-app": "node scripts/prepare-dev-electron-app.mjs",
    "diagnose:recording": "node scripts/recording-diagnostics.mjs",
    "native:build": "node scripts/build-native-capture.mjs",
    "native:build:shared-texture-probe": "node scripts/build-recording-v3-shared-texture-probe.mjs --native-only",
    "native:build:recording-v3": "node scripts/build-recording-v3-native-addon.mjs",
    "native:verify:packaged": "node scripts/verify-packaged-native-capture.mjs",
    "electron:build:shared-texture-probe": "node scripts/build-recording-v3-shared-texture-probe.mjs --entry-only",
    "electron:build:recording-v3-production-probe": "node scripts/build-recording-v3-production-probe.mjs",
    "recording:v3:certify:60s": "node scripts/recording-v3-certification-60s.mjs",
    "recording:v3:certify:10m": "node scripts/recording-v3-certification-10m.mjs",
    "recording:v3:manifest:sign": "node scripts/recording-v3-certification-sign-manifest.mjs",
    "recording:v3:release:verify": "node scripts/recording-v3-release-verify.mjs",
    "test:e2e:cursor-sync": "pnpm electron:build-main && playwright test --config playwright.config.ts e2e/cursor-sync.spec.ts",
    "test:e2e:scroll": "pnpm electron:build-main && playwright test --config playwright.config.ts e2e/smooth-scroll.spec.ts",
    "test:e2e:media": "pnpm electron:build-main && playwright test --config playwright.config.ts e2e/media-playback.spec.ts",
    "test:e2e:export": "pnpm native:build && pnpm electron:build-main && pnpm renderer:build && electron-builder --dir --publish never && node scripts/export-compositor-artifact-smoke.mjs",
    "test:e2e:recording-v2-helper": "pnpm native:build && pnpm electron:build-main && pnpm renderer:build && electron-builder --dir --publish never && pnpm native:verify:packaged",
    "test:e2e:recording-v3-shared-texture-probe": "pnpm native:build && pnpm electron:build-main && pnpm renderer:build && pnpm electron:build:shared-texture-probe && electron-builder --dir --publish never --config.extraMetadata.main=dist-electron/recording-v3-shared-texture-probe.mjs && node scripts/run-recording-v3-shared-texture-probe.mjs",
    "test:e2e:recording-v3-production-probe": "pnpm native:build && pnpm electron:build-main && pnpm renderer:build && pnpm electron:build:recording-v3-production-probe && electron-builder --dir --publish never --config.extraMetadata.main=dist-electron/recording-v3-production-probe.mjs && node scripts/run-recording-v3-production-probe.mjs",
    "test:e2e:recording-v3-development-flow": "pnpm native:build:recording-v3 && pnpm electron:build-main && node scripts/run-recording-v3-development-flow.mjs",
    "test:e2e:recording-v3-60s": "pnpm native:build && pnpm electron:build-main && pnpm renderer:build && pnpm electron:build:recording-v3-production-probe && electron-builder --dir --publish never --config.extraMetadata.main=dist-electron/recording-v3-production-probe.mjs && pnpm recording:v3:certify:60s",
    "test:e2e:recording-v3-soak": "pnpm recording:v3:certify:10m",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@dnd-kit/core": "^6.3.1",
    "@ffprobe-installer/ffprobe": "2.1.2",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@lezer/highlight": "^1.2.3",
    "@sindresorhus/slugify": "^3.0.0",
    "@storycapture/shared-types": "workspace:*",
    "@storycapture/story-dsl": "workspace:*",
    "@storycapture/ui": "workspace:*",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-virtual": "^3",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "@uiw/react-codemirror": "^4.25.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "electron-updater": "^6.8.9",
    "fast-deep-equal": "3.1.3",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hotkeys-hook": "^5.3.3",
    "react-resizable-panels": "^4.10.0",
    "react-router-dom": "^7.18.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "wavesurfer.js": "^7.12.10",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/ui": "^4.1.10",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.storycapture.desktop",
    "productName": "StoryCapture",
    "directories": {
      "output": "release-electron"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "icons/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web/node_modules/next/dist/compiled/@vercel/og/Geist-Regular.ttf",
        "to": "assets/fonts/Geist-Regular.ttf"
      },
      {
        "from": "recording-v3-certification",
        "to": "recording-v3-certification"
      },
      {
        "from": "fixtures/recording-v3-certification",
        "to": "recording-v3-certification-fixture"
      }
    ],
    "mac": {
      "category": "public.app-category.video",
      "icon": "icons/icon.icns",
      "extraResources": [
        {
          "from": "native/macos-screen-capture/.build/release/storycapture-screen-capture-helper",
          "to": "native/macos/storycapture-screen-capture-helper"
        },
        {
          "from": "native/macos-shared-texture-probe/.build/storycapture_shared_texture_probe.node",
          "to": "native/macos/storycapture_shared_texture_probe.node"
        },
        {
          "from": "native/macos-recording-v3/.build/storycapture_recording_v3.node",
          "to": "native/macos/storycapture_recording_v3.node"
        },
        {
          "from": "native/macos-shared-texture-probe/fixture.html",
          "to": "native/macos/shared-texture-probe-fixture.html"
        }
      ],
      "extendInfo": {
        "NSMicrophoneUsageDescription": "StoryCapture records optional voice-over audio while capturing demos."
      }
    },
    "win": {
      "target": "nsis",
      "icon": "icons/icon.ico",
      "extraResources": [
        {
          "from": "native/windows-capture/bin/${arch}/storycapture-wgc.exe",
          "to": "native/windows/${arch}/storycapture-wgc.exe"
        }
      ]
    },
    "linux": {
      "icon": "icons/icon.png"
    }
  }
}
