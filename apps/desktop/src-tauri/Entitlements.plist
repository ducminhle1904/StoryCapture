<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    StoryCapture desktop entitlements (Phase 1 plan 01-03).
    Mirrors scripts/notarize/smoke-app/src-tauri/Entitlements.plist (Plan 01-02)
    and adds the runtime-permission requests appropriate for the production app.

    Per D-41 + PITFALLS.md §2:
      - Hardened runtime is enabled in tauri.conf.json (bundle.macOS.hardenedRuntime).
      - Screen Recording is a TCC permission, NOT an entitlement — granted by
        the user via Settings → Privacy & Security → Screen Recording. Do not
        declare it here.
      - Accessibility is also TCC, not an entitlement.
  -->

  <!-- FFmpeg sidecar uses JIT-style code paths in some filters/codecs. -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- Capture pipeline needs audio input (system audio via SCK on macOS). -->
  <key>com.apple.security.device.audio-input</key>
  <true/>

  <!--
    Camera explicitly denied: capture path is screen-only, not webcam.
    If a future feature adds webcam capture, change to <true/> AND add a
    NSCameraUsageDescription to Info.plist.
  -->
  <key>com.apple.security.device.camera</key>
  <false/>

  <!--
    We deliberately do NOT add com.apple.security.cs.disable-library-validation
    because the FFmpeg sidecar is statically linked (D-22) — there are no
    nested dylibs that need un-validated loading. If a future build reverts
    to dynamic linking, add the entitlement here.
  -->
</dict>
</plist>
