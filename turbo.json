{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "inputs": ["src/**", "electron/**", "scripts/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**", "release-electron/**", ".next/**", "!.next/cache/**"],
      "inputs": [
        "src/**",
        "electron/**",
        "scripts/**",
        "package.json",
        "tsconfig.json",
        "vite.config.*"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "electron/**", "scripts/**", "tsconfig.json", "package.json"]
    },
    "lint": {
      "inputs": ["src/**", "biome.json", "package.json"]
    }
  }
}
