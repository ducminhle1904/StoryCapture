{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "inputs": ["src/**", "Cargo.toml", "Cargo.lock", "**/Cargo.toml"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "inputs": [
        "src/**",
        "package.json",
        "tsconfig.json",
        "Cargo.toml",
        "Cargo.lock",
        "**/Cargo.toml"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json", "package.json"]
    },
    "lint": {
      "inputs": ["src/**", "biome.json", "package.json"]
    }
  }
}
