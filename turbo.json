{
  "$schema": "https://v2-10-4.turborepo.dev/schema.json",
  "ui": "stream",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "inputs": ["src/**", "electron/**", "scripts/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        "dist-electron/**",
        "release-electron/**",
        ".next/**",
        "!.next/cache/**"
      ],
      "inputs": [
        "src/**",
        "!src/generated/**",
        "electron/**",
        "prisma/schema.prisma",
        "scripts/**",
        "package.json",
        "tsconfig.json",
        "vite.config.*"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "!src/generated/**",
        "electron/**",
        "prisma/schema.prisma",
        "scripts/**",
        "tsconfig.json",
        "package.json"
      ]
    },
    "lint": {
      "inputs": ["src/**", "biome.json", "package.json"]
    }
  }
}
