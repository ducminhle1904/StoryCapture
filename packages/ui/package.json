{
  "name": "@storycapture/ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./theme": {
      "types": "./src/theme/index.ts",
      "import": "./src/theme/index.ts"
    },
    "./theme.css": "./src/theme/generated/storycapture-gothic.css",
    "./fonts.css": "./src/theme/fonts.css",
    "./product-tokens.css": "./src/theme/product-tokens.css"
  },
  "scripts": {
    "theme:build": "astryx theme build src/theme/storycapture-gothic.ts --out src/theme/generated/storycapture-gothic.css",
    "theme:check": "node scripts/check-theme.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@astryxdesign/core": "0.1.6",
    "@astryxdesign/theme-gothic": "0.1.6",
    "@fontsource-variable/fustat": "5.3.0",
    "@fontsource-variable/jetbrains-mono": "5.3.0",
    "@fontsource/manufacturing-consent": "5.3.0",
    "@stylexjs/stylex": "0.19.0"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@astryxdesign/cli": "0.1.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "happy-dom": "^20.10.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
