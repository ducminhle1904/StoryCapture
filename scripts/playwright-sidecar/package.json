{
  "name": "playwright-sidecar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "server.mjs",
  "description": "StoryCapture Playwright sidecar — JSON-RPC over stdin/stdout, packaged as a Node 20 SEA binary and shipped as a Tauri externalBin sidecar.",
  "scripts": {
    "dev": "node server.mjs",
    "install-browser": "playwright install chromium",
    "build:sea": "node build-sea.mjs",
    "build:overlay": "esbuild picker/overlay/index.ts --bundle --format=iife --platform=browser --target=es2022 --outfile=picker/overlay/overlay.iife.js",
    "pretest": "esbuild picker/overlay/index.ts --bundle --format=iife --platform=browser --target=es2022 --outfile=picker/overlay/overlay.iife.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "playwright-core": "^1.59.1"
  },
  "devDependencies": {
    "@medv/finder": "4.0.2",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.2",
    "postject": "^1.0.0-alpha.6",
    "vitest": "^4.1.5"
  }
}
